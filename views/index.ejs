<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Sistem Inventaris Baterai</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <div class="container-fluid py-4">
        <h2 class="text-center mb-4 fw-bold">Dashboard Inventaris (Gudang)</h2>

        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="card border-0 shadow-sm bg-primary text-white">
                    <div class="card-body">
                        <small>Total Nilai Aset (Gudang)</small>
                        <h3 class="fw-bold">Rp <%= Number(summary.total_aset || 0).toLocaleString('id-ID') %></h3>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card border-0 shadow-sm bg-success text-white">
                    <div class="card-body">
                        <small>Profit Nyata (Dari Terjual)</small>
                        <h3 class="fw-bold">Rp <%= Number(summary.profit_nyata || 0).toLocaleString('id-ID') %></h3>
                    </div>
                </div>
            </div>
        </div>

<div class="card shadow-sm mb-4 border-0">
    <div class="card-body">
        <h5 class="fw-bold mb-3"><i class="bi bi-graph-up-arrow text-danger"></i> Produk Terlaris (Top 5)</h5>
        <div class="row">
            <% if (top_selling.length > 0) { %>
                <% top_selling.forEach((item, index) => { %>
                    <div class="col-md-2 text-center">
                        <div class="p-2 border rounded bg-light">
                            <div class="small text-muted">#<%= index + 1 %></div>
                            <div class="fw-bold text-truncate"><%= item.nama_barang %></div>
                            <span class="badge bg-danger"><%= item.total_laku %> Terjual</span>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12 text-center py-3">
                    <p class="text-muted small mb-0">Belum ada data penjualan untuk ditampilkan.</p>
                </div>
            <% } %>
        </div>
    </div>
</div>

        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <button class="btn btn-outline-primary mb-3" data-bs-toggle="collapse" data-bs-target="#formMaster">
                    <i class="bi bi-plus-circle"></i> Tambah Jenis Barang Baru ke Pilihan
                </button>

                <div class="collapse mb-4" id="formMaster">
                    <div class="card card-body bg-light border-0">
                        <h5>Daftarkan Jenis Barang Baru</h5>
                        <form action="/tambah-master" method="POST" class="row g-3">
                            <div class="col-md-5">
                                <input type="text" name="nama_barang" class="form-control" placeholder="Nama Barang Baru" required>
                            </div>
                            <div class="col-md-5">
                                <input type="text" name="kode_sku" class="form-control" placeholder="Kode SKU" required>
                            </div>
                            <div class="col-md-2">
                                <button type="submit" class="btn btn-primary w-100">Simpan Ke Pilihan</button>
                            </div>
                        </form>
                    </div>
                </div>

                <form action="/simpan" method="POST" class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Nama Barang</label>
                        <select name="nama_barang" id="selectBarang" class="form-select" onchange="updateSKU()" required>
                            <option value="">-- Pilih Barang --</option>
                            <% data_master.forEach(m => { %>
                                <option value="<%= m.nama_barang %>" data-sku="<%= m.kode_sku %>">
                                    <%= m.nama_barang %> (<%= m.kode_sku %>)
                                </option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Kode SKU</label>
                        <input type="text" name="kode_sku" id="inputSKU" class="form-control" readonly>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Kondisi</label>
                        <select name="kondisi" class="form-select">
                            <option value="BAGUS">BAGUS</option>
                            <option value="RUSAK">RUSAK</option>
                        </select>
                    </div>
                    <div class="col-md-1">
                        <label class="form-label">Stok</label>
                        <input type="number" name="stok" class="form-control" value="0">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Modal</label>
                        <input type="number" name="modal" class="form-control" placeholder="Rp">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Harga Jual</label>
                        <input type="number" name="harga_jual" class="form-control" placeholder="Rp">
                    </div>
                    <div class="col-12 text-end">
                        <button type="submit" class="btn btn-success px-5">Tambah Barang</button>
                    </div>
                </form>
            </div>
        </div>

        <% for (const bulan in data_per_bulan) { %>
            <h4 class="mt-5 mb-3 text-primary fw-bold">📅 Periode: <%= bulan %></h4>
            <div class="card shadow-sm mb-4 border-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 text-center">
                        <thead class="table-dark">
                            <tr>
                                <th class="text-start">WAKTU TRANSAKSI</th>
                                <th class="text-start">NAMA BARANG</th>
                                <th>KONDISI</th>
                                <th>STOK AWAL</th>
                                <th>SISA STOK</th>
                                <th>MODAL</th>
                                <th>HARGA JUAL</th>
                                <th>AKSI</th>
                                <th class="bg-success text-white">PROFIT TERJUAL</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% data_per_bulan[bulan].forEach(item => { %>
                            <tr class="<%= item.stok <= item.minimal_stok ? 'table-danger' : '' %>">
                                <td class="text-start small">
                                    <strong><%= new Date(item.waktu_input).toLocaleDateString('id-ID', { weekday: 'long', day: 'numeric', month: 'long' }) %></strong><br>
                                    <span class="text-muted"><%= new Date(item.waktu_input).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }) %> WIB</span>
                                </td>
                                <td class="text-start">
                                    <div class="fw-bold"><%= item.nama_barang %></div>
                                    <span class="badge bg-secondary" style="font-size: 0.7rem;"><%= item.kode_sku %></span>
                                </td>
                                <td><span class="badge btn-outline-dark text-dark border"><%= item.kondisi %></span></td>
                                <td class="text-muted"><%= item.stok_awal %></td>
                                <td class="fw-bold text-primary"><%= item.stok %></td>
                                <td class="text-secondary small">Rp <%= Number(item.modal).toLocaleString('id-ID') %></td> <td class="fw-bold">Rp <%= Number(item.harga_jual).toLocaleString('id-ID') %></td>                                
                                <td>
                            
                                <div class="d-flex justify-content-center gap-1">
                                    <form action="/jual/<%= item.id %>" method="POST" class="d-flex gap-1">
                                        <input type="number" name="jumlah_jual" value="1" class="form-control form-control-sm" style="width: 50px;">
                                        <button type="submit" class="btn btn-sm btn-success">Jual</button>
                                    </form>
                                    <a href="/hapus/<%= item.id %>" class="btn btn-sm btn-outline-danger" 
                                        onclick="return confirm('Hapus data barang ini?')">🗑</a>
                                    </div>                            
                                </td>            
<td class="fw-bold text-end">
    <% 
        // 1. Pastikan angka diproses dengan benar
        let sAwal = Number(item.stok_awal) || 1;
        let mTotal = Number(item.modal) || 0;
        let hJual = Number(item.harga_jual) || 0;
        let jTerjual = Number(item.jumlah_terjual) || 0;

        // 2. Hitung Modal per pcs dan Profit
        let modalPerPcs = mTotal / sAwal;
        let untungPerPcs = hJual - modalPerPcs;
        let totalProfitItem = untungPerPcs * jTerjual;
    %>
    
    <% if (totalProfitItem > 0) { %>
        <span class="text-success">Rp <%= Number(totalProfitItem).toLocaleString('id-ID') %></span>
    <% } else if (totalProfitItem < 0) { %>
        <span class="text-danger">Rp <%= Number(totalProfitItem).toLocaleString('id-ID') %></span>
    <% } else { %>
        <span class="text-muted">Rp 0</span>
    <% } %>
    
    <br><small class="text-muted" style="font-size: 0.7rem;">(<%= jTerjual %> terjual)</small>
</td>                              
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        <% } %>
    </div>

    <a href="/history" class="btn btn-outline-dark mb-3">
    <i class="bi bi-list-check"></i> Lihat Riwayat
</a>

<a href="/produksi" class="btn btn-warning fw-bold mb-3 shadow-sm">
    <i class="bi bi-tools"></i> Masuk ke Modul Produksi
</a>

<script>
function updateSKU() {
    const select = document.getElementById('selectBarang');
    const skuInput = document.getElementById('inputSKU');
    const selectedOption = select.options[select.selectedIndex];
    const sku = selectedOption.getAttribute('data-sku');
    skuInput.value = sku || "";
}
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>