<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Riwayat Penjualan - Sistem Baterai</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/"><i class="bi bi-arrow-left"></i> Kembali ke Dashboard</a>
            <span class="navbar-text text-white">Log Transaksi Keluar</span>
        </div>
    </nav>

    <div class="container">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white py-3">
                <h4 class="mb-0 fw-bold text-primary"><i class="bi bi-clock-history"></i> Riwayat Keseluruhan</h4>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped align-middle">
                        <thead class="table-primary">
                            <tr>
                                <th class="text-center">No</th>
                                <th>Waktu Transaksi</th>
                                <th>Nama Barang</th>
                                <th>Harga Satuan</th>
                                <th class="text-center">Aktivitas</th>
                                <th class="text-center">Jumlah Keluar/Masuk</th>
                                <th>Penanggung Jawab</th>
                                <th class="text-center">Status</th> </tr>
                        </thead>
                        <tbody>
                            <% history.forEach((row, index) => { %>
                            <tr>
                                <td class="text-center"><%= index + 1 %></td>
                                <td><%= row.waktu_format %> WIB</td>
                                <td class="fw-bold"><%= row.nama_barang_saat_itu || row.nama_barang %></td>

                                <td class="text-end">
                                    <% if(row.harga_satuan_log > 0) { %>
                                        Rp <%= row.harga_satuan_log.toLocaleString('id-ID') %>
                                    <% } else { %>
                                        <span class="text-muted small">N/A</span>
                                    <% } %>
                                </td>    

                                <td>
                                    <span class="badge 
                                        <%= row.aktivitas === 'Produksi-Masuk (Rakit)' ? 'bg-success' : 
                                           row.aktivitas === 'Produksi-Keluar (Rakit)' ? 'bg-warning text-dark' : 'bg-info' %>">
                                        <%= row.aktivitas %>
                                    </span>
                                </td>                            

                                <td class="text-center fw-bold">
                                    <% if (row.aktivitas === 'Produksi-Masuk (Rakit)') { %>
                                        <span class="text-success"><%= Math.abs(row.jumlah_perubahan) %> pcs</span>
                                    <% } else if (row.aktivitas === 'Produksi-Keluar (Rakit)' || row.aktivitas === 'Penjualan') { %>
                                        <span class="text-danger">- <%= Math.abs(row.jumlah_perubahan) %> pcs</span>
                                    <% } else { %>
                                        <%= row.jumlah_perubahan %> pcs
                                    <% } %>
                                </td>
                            
                                <td>
                                    <% if(row.penanggung_jawab) { %>
                                        <i class="bi bi-person-fill"></i> <%= row.penanggung_jawab %>
                                    <% } else { %>
                                        <span class="text-muted small">-</span>
                                    <% } %>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-success"><i class="bi bi-check-circle"></i> Berhasil</span>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>                            
                </div>
            </div>
        </div>
    </div>
</body>
</html>